{
  "name": "next-countries",
  "version": "1.0.2",
  "description": "Simple country list optimized for Next.js App Router and React Server Components.",
  "keywords": [
    "countries",
    "name",
    "code",
    "alpha3",
    "numeric",
    "nextjs",
    "iso-3166",
    "react"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rironib/next-countries.git"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup index.ts --format esm --dts --clean --minify",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  },
  "license": "MIT"
}
